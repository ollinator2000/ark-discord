{
  "rules": [
    {
      "name": "player_joined",
      "pattern": "^\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\]\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: (?P<player>.+?) \\[UniqueNetId:(?P<netid>[0-9a-fA-F]+) Platform:(?P<platform>[^\\]]+)\\] joined this ARK!$",
      "title": "Spieler beigetreten",
      "description": "**{player}** ist dem Server beigetreten.",
      "emoji": "🟢",
      "color": 3066993,
      "event_class": "high",
      "fields": [
        { "name": "Spieler", "value": "{player}" },
        { "name": "Platform", "value": "{platform}" },
        { "name": "NetId", "value": "`{netid}`" }
      ]
    },
    {
      "name": "player_left",
      "pattern": "^\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\]\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: (?P<player>.+?) \\[UniqueNetId:(?P<netid>[0-9a-fA-F]+) Platform:(?P<platform>[^\\]]+)\\] left this ARK!$",
      "title": "Spieler verlassen",
      "description": "**{player}** hat den Server verlassen.",
      "emoji": "🔴",
      "color": 15158332,
      "event_class": "high",
      "fields": [
        { "name": "Spieler", "value": "{player}" },
        { "name": "Platform", "value": "{platform}" },
        { "name": "NetId", "value": "`{netid}`" }
      ]
    },
    {
      "name": "player_death_by",
      "pattern": "^\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\]\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: (?P<player>.+?) - Lvl (?P<level>\\d+) \\([^\\)]*\\) was killed by (?P<killer>.+?)!$",
      "title": "Spielertod",
      "description": "**{player}** (Lvl {level}) wurde von **{killer}** getoetet.",
      "emoji": "☠️",
      "color": 10038562,
      "event_class": "high",
      "fields": [
        { "name": "Spieler", "value": "{player}" },
        { "name": "Level", "value": "{level}" },
        { "name": "Killer", "value": "{killer}" }
      ]
    },
    {
      "name": "player_death_unknown",
      "pattern": "^\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\]\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: (?P<player>.+?) - Lvl (?P<level>\\d+) \\([^\\)]*\\) was killed!$",
      "title": "Spielertod",
      "description": "**{player}** (Lvl {level}) ist gestorben.",
      "emoji": "⚰️",
      "color": 8359053,
      "event_class": "high",
      "fields": [
        { "name": "Spieler", "value": "{player}" },
        { "name": "Level", "value": "{level}" }
      ]
    },
    {
      "name": "pve_tame_completed",
      "pattern": "^(?:.+?:)?\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\]\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: (?P<player>.+?) of Tribe\\s*(?P<tribe>.*?)\\s*Tamed (?:an|a) (?P<dino>.+?) - Lvl (?P<level>\\d+) \\((?P<species>[^\\)]+)\\)!$",
      "title": "Neuer Tame",
      "description": "**{player}** hat **{dino}** (Lvl {level}) gezähmt.",
      "emoji": "🦖",
      "color": 5763719,
      "event_class": "normal",
      "fields": [
        { "name": "Spieler", "value": "{player}" },
        { "name": "Tribe", "value": "{tribe}" },
        { "name": "Dino", "value": "{dino}" },
        { "name": "Level", "value": "{level}" },
        { "name": "Species", "value": "{species}" }
      ]
    },
    {
      "name": "pve_dino_killed",
      "pattern": "^\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\]\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: (?P<killer>.+?) (?:- Lvl \\d+ \\(\\) )?killed (?:(?:wild )?(?:an|a) )?(?P<dino>.+?)(?: - Lvl \\d+)?(?: \\(\\))?!$",
      "title": "Dino getoetet",
      "description": "**{killer}** hat **{dino}** getoetet.",
      "emoji": "🏹",
      "color": 3447003,
      "event_class": "normal",
      "fields": [
        { "name": "Killer", "value": "{killer}" },
        { "name": "Dino", "value": "{dino}" }
      ]
    },
    {
      "name": "pve_building_placement",
      "pattern": "^\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\]\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: (?P<player>.+?) placed (?:an|a) (?P<structure>.+?)(?:\\.|!|)$",
      "title": "Building Placement",
      "description": "**{player}** hat **{structure}** platziert.",
      "emoji": "🏗️",
      "color": 1752220,
      "event_class": "burst",
      "aggregation_window_seconds": 20,
      "aggregate_key": "{structure}",
      "fields": [
        { "name": "Spieler", "value": "{player}" },
        { "name": "Struktur", "value": "{structure}" }
      ]
    },
    {
      "name": "pve_structure_destroyed",
      "pattern": "^(?:.+?:)?\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\](?:(?:\\d{4}\\.\\d{2}\\.\\d{2}_\\d{2}\\.\\d{2}\\.\\d{2}: )?(?P<attacker>.+?) destroyed )?Structure (?P<structure>.+?) destroyed at (?P<x>-?\\d+) (?P<y>-?\\d+) (?P<z>-?\\d+) .*!$",
      "title": "Structure zerstoert",
      "description": "**{structure}** wurde zerstoert.",
      "emoji": "💥",
      "color": 16098851,
      "event_class": "burst",
      "aggregation_window_seconds": 30,
      "aggregate_key": "{structure}",
      "fields": [
        { "name": "Struktur", "value": "{structure}" },
        { "name": "Angreifer", "value": "{attacker}" },
        { "name": "Position", "value": "X:{x} Y:{y} Z:{z}" }
      ]
    },
    {
      "name": "ingame_chat_message",
      "pattern": "^(?:.+?:)?\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\].*?(?P<channel>Global|Tribe|Local)\\s+Chat(?:\\s+Message)?(?:\\s+from)?\\s*[\\\"']?(?P<player>[^:\\\"']+)[\\\"']?\\s*:\\s*(?P<message>.+)$",
      "title": "Ingame Chat",
      "description": "**{player}**: {message}",
      "emoji": "💬",
      "color": 10181046,
      "event_class": "normal",
      "fields": [
        { "name": "Kanal", "value": "{channel}" },
        { "name": "Spieler", "value": "{player}" }
      ]
    },
    {
      "name": "ingame_chat_message_generic",
      "pattern": "^(?:.+?:)?\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\].*?Chat(?:\\s+Message)?(?:\\s+from)?\\s*[\\\"']?(?P<player>[^:\\\"']+)[\\\"']?\\s*:\\s*(?P<message>.+)$",
      "title": "Ingame Chat",
      "description": "**{player}**: {message}",
      "emoji": "💬",
      "color": 10181046,
      "event_class": "normal",
      "fields": [
        { "name": "Spieler", "value": "{player}" }
      ]
    },
    {
      "name": "server_started",
      "pattern": "^(?:.+?:)?\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\].*(?i:server started|server is starting|server up and running|server:\\s*\\\"?.+?\\\"?\\s*has\\s+successfully\\s+started!?).*$",
      "title": "Server gestartet",
      "description": "Der ARK Server wurde gestartet.",
      "emoji": "✅",
      "color": 3066993,
      "event_class": "high",
      "fields": [
        { "name": "Status", "value": "Server gestartet" }
      ]
    },
    {
      "name": "server_stopped",
      "pattern": "^(?:.+?:)?\\[(?P<logtime>[^\\]]+)\\]\\[\\s*\\d+\\].*(?i:server stopped|server shutdown|server is shutting down).*$",
      "title": "Server gestoppt",
      "description": "Der ARK Server wurde gestoppt.",
      "emoji": "🛑",
      "color": 15158332,
      "event_class": "high",
      "fields": [
        { "name": "Status", "value": "Server gestoppt" }
      ]
    }
  ]
}
